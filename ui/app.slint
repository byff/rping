// PingTest - Slint UI Application
// A network ping testing tool with results table and export capabilities

// === TABLE ROW STRUCTURE ===
struct TableRow {
    num: int,
    hostname: string,
    ip: string,
    success: int,
    fail: int,
    fail_pct: string,
    total: int,
    rtt: string,
    rtt_max: string,
    rtt_min: string,
    rtt_avg: string,
    status: int  // -1=unknown, 0=alive, 1=partial, 2=failed
}

export component MainWindow {
    // === COLOR PALETTE ===
    property <color> accent: #409CFF;
    property <color> success: #50C878;
    property <color> fail: #FF5555;
    property <color> warning: #FFB432;
    property <color> text_dim: #787D87;
    property <color> bg: #181A20;
    property <color> window_fill: #181A26;

    // === WINDOW PROPERTIES ===
    property <string> status_message: "Ready";
    property <string> input_text: "";
    property <bool> is_running: false;
    property <int> selected_ip_count: 0;

    // === TABLE DATA ===
    property <int> sort_column: 0;
    property <bool> sort_descending: false;

    // === SETTINGS PROPERTIES ===
    property <int> timeout_value: 1000;
    property <int> packet_size_value: 64;
    property <int> interval_value: 1000;
    property <int> max_concurrent_value: 100;
    property <bool> cidr_enabled: true;
    property <bool> remember_addresses: true;
    property <bool> debug_mode: false;

    // === EXPORT FIELD CHECKBOXES ===
    property <bool> export_hostname: true;
    property <bool> export_ip: true;
    property <bool> export_success: true;
    property <bool> export_fail: true;
    property <bool> export_fail_percent: true;
    property <bool> export_total: true;
    property <bool> export_rtt: true;
    property <bool> export_max: true;
    property <bool> export_min: true;
    property <bool> export_avg: true;

    // === DIALOG STATES ===
    property <bool> settings_dialog_open: false;
    property <bool> ip_warning_dialog_open: false;
    property <bool> about_dialog_open: false;

    // === SAMPLE TABLE DATA ===
    property <[TableRow]> table_rows: [
        { num: 1, hostname: "router.local", ip: "192.168.1.1", success: 10, fail: 0, fail_pct: "0%", total: 10, rtt: "1.5ms", rtt_max: "2.1ms", rtt_min: "1.2ms", rtt_avg: "1.5ms", status: 0 },
        { num: 2, hostname: "server1.local", ip: "192.168.1.10", success: 8, fail: 2, fail_pct: "20%", total: 10, rtt: "5.3ms", rtt_max: "8.2ms", rtt_min: "3.1ms", rtt_avg: "5.1ms", status: 1 },
        { num: 3, hostname: "server2.local", ip: "192.168.1.11", success: 3, fail: 7, fail_pct: "70%", total: 10, rtt: "12.5ms", rtt_max: "25.0ms", rtt_min: "8.0ms", rtt_avg: "14.2ms", status: 2 },
        { num: 4, hostname: "unknown.host", ip: "10.0.0.1", success: 0, fail: 0, fail_pct: "-", total: 0, rtt: "-", rtt_max: "-", rtt_min: "-", rtt_avg: "-", status: -1 },
    ];

    // === CALLBACKS ===
    callback start_ping();
    callback stop_ping();
    callback refresh_results();
    callback import_ips();
    callback export_results();
    callback insert_to_source();
    callback open_settings();
    callback open_about();
    callback close_settings();
    callback save_settings();
    callback reset_settings();
    callback ip_warning_continue();
    callback ip_warning_cancel();
    callback close_about();
    callback sort_table(int);

    width: 1000px;
    height: 700px;
    background: root.bg;
    title: "PingTest";

    // === MAIN LAYOUT ===
    VerticalLayout {
        padding: 0;
        spacing: 0;

        // === TOOLBAR ===
        Rectangle {
            background: root.window_fill;
            height: 48px;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                // Start Button
                Rectangle {
                    border_radius: 4px;
                    background: root.is_running ? root.text_dim : root.success;
                    horizontal_stretch: 0;
                    width: 70px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Start";
                        color: white;
                        font_size: 13px;
                        font_weight: 700;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            if (!root.is_running) {
                                root.is_running = true;
                                root.status_message = "Pinging...";
                                root.start_ping();
                            }
                        }
                    }
                }

                // Stop Button
                Rectangle {
                    border_radius: 4px;
                    background: !root.is_running ? root.text_dim : root.fail;
                    width: 70px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Stop";
                        color: white;
                        font_size: 13px;
                        font_weight: 700;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            if (root.is_running) {
                                root.is_running = false;
                                root.status_message = "Stopped";
                                root.stop_ping();
                            }
                        }
                    }
                }

                // Refresh Button
                Rectangle {
                    border_radius: 4px;
                    background: root.warning;
                    width: 80px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Refresh";
                        color: white;
                        font_size: 13px;
                        font_weight: 700;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.refresh_results();
                        }
                    }
                }

                // Separator
                Rectangle {
                    width: 1px;
                    background: root.text_dim;
                    horizontal_stretch: 0;
                    width: 10px;
                }

                // Import Button
                Rectangle {
                    border_radius: 4px;
                    background: root.accent;
                    width: 70px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Import";
                        color: white;
                        font_size: 13px;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.import_ips();
                        }
                    }
                }

                // Export Results Button
                Rectangle {
                    border_radius: 4px;
                    background: root.accent;
                    width: 100px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Export Results";
                        color: white;
                        font_size: 13px;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.export_results();
                        }
                    }
                }

                // Insert to Source Button
                Rectangle {
                    border_radius: 4px;
                    background: root.accent;
                    width: 110px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Insert to Source";
                        color: white;
                        font_size: 13px;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.insert_to_source();
                        }
                    }
                }

                // Spacer
                Rectangle { horizontal_stretch: 1; }

                // Settings Button
                Rectangle {
                    border_radius: 4px;
                    background: root.text_dim;
                    width: 80px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "Settings";
                        color: white;
                        font_size: 13px;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.settings_dialog_open = true;
                        }
                    }
                }

                // About Button
                Rectangle {
                    border_radius: 4px;
                    background: root.text_dim;
                    width: 70px;
                    height: 32px;
                    cursor: MouseCursor.pointer;

                    Text {
                        text: "About";
                        color: white;
                        font_size: 13px;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.about_dialog_open = true;
                        }
                    }
                }
            }
        }

        // === MAIN CONTENT AREA ===
        VerticalLayout {
            padding: 10px;
            spacing: 10px;
            vertical_stretch: 1;

            // === IP INPUT SECTION ===
            Rectangle {
                background: root.window_fill;
                border_radius: 6px;
                height: 120px;

                VerticalLayout {
                    padding: 8px;

                    Text {
                        text: "IP Addresses";
                        color: root.accent;
                        font_size: 12px;
                        font_weight: 700;
                    }

                    TextEdit {
                        placeholder_text: "Enter IP addresses, one per line or CIDR format";
                        text <=> root.input_text;
                        font_size: 13px;
                        wrap: TextWrap.wrap;
                        horizontal_stretch: 1;
                        vertical_stretch: 1;
                    }
                }
            }

            // === RESULTS TABLE ===
            Rectangle {
                background: root.window_fill;
                border_radius: 6px;
                vertical_stretch: 1;

                VerticalLayout {
                    padding: 0;
                    spacing: 0;

                    // Table Header
                    Rectangle {
                        background-color: #252830;
                        height: 32px;

                        HorizontalLayout {
                            padding-left: 4px;
                            padding-right: 4px;
                            spacing: 0;

                            // # Column
                            Rectangle {
                                width: 40px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "#";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(0); }
                                }
                            }

                            // Hostname Column
                            Rectangle {
                                width: 130px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Hostname";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(1); }
                                }
                            }

                            // IP Column
                            Rectangle {
                                width: 120px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "IP";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(2); }
                                }
                            }

                            // Success Column
                            Rectangle {
                                width: 60px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Success";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(3); }
                                }
                            }

                            // Fail Column
                            Rectangle {
                                width: 50px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Fail";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(4); }
                                }
                            }

                            // Fail% Column
                            Rectangle {
                                width: 60px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Fail%";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(5); }
                                }
                            }

                            // Total Column
                            Rectangle {
                                width: 55px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Total";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(6); }
                                }
                            }

                            // RTT Column
                            Rectangle {
                                width: 80px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "RTT(ms)";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(7); }
                                }
                            }

                            // Max Column
                            Rectangle {
                                width: 75px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Max";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(8); }
                                }
                            }

                            // Min Column
                            Rectangle {
                                width: 75px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Min";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(9); }
                                }
                            }

                            // Avg Column
                            Rectangle {
                                width: 75px;
                                cursor: MouseCursor.pointer;

                                Text {
                                    text: "Avg";
                                    color: root.accent;
                                    font_size: 12px;
                                    font_weight: 700;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                TouchArea {
                                    clicked => { root.sort_table(10); }
                                }
                            }
                        }
                    }

                    // Table Body (Scrollable)
                    ListView {
                        vertical_stretch: 1;

                        for row[i] in root.table_rows: Rectangle {
                            background: Math.mod(i, 2) == 0 ? root.window_fill : #1E2128;
                            height: 28px;

                            HorizontalLayout {
                                padding-left: 4px;
                                padding-right: 4px;
                                spacing: 0;

                                // # 
                                Text {
                                    width: 40px;
                                    text: row.num;
                                    color: root.text_dim;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Hostname
                                Text {
                                    width: 130px;
                                    text: row.hostname;
                                    color: white;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // IP with status color
                                Text {
                                    width: 120px;
                                    text: row.ip;
                                    color: row.status == 0 ? root.success : (row.status == 1 ? root.warning : (row.status == 2 ? root.fail : root.text_dim));
                                    font_size: 12px;
                                    font_weight: row.status == 0 ? bold : normal;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Success
                                Text {
                                    width: 60px;
                                    text: row.success;
                                    color: root.success;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Fail
                                Text {
                                    width: 50px;
                                    text: row.fail;
                                    color: root.fail;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Fail% with color coding
                                Text {
                                    width: 60px;
                                    text: row.fail_pct;
                                    color: row.fail_pct == "-" ? root.text_dim : (row.fail_pct == "0%" ? root.success : (row.fail_pct == "10%" ? root.warning : (row.fail > 5 ? root.fail : root.warning)));
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Total
                                Text {
                                    width: 55px;
                                    text: row.total;
                                    color: white;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // RTT
                                Text {
                                    width: 80px;
                                    text: row.rtt;
                                    color: row.rtt == "-" ? root.text_dim : root.accent;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Max
                                Text {
                                    width: 75px;
                                    text: row.rtt_max;
                                    color: row.rtt_max == "-" ? root.text_dim : root.accent;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Min
                                Text {
                                    width: 75px;
                                    text: row.rtt_min;
                                    color: row.rtt_min == "-" ? root.text_dim : root.accent;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }

                                // Avg
                                Text {
                                    width: 75px;
                                    text: row.rtt_avg;
                                    color: row.rtt_avg == "-" ? root.text_dim : root.accent;
                                    font_size: 12px;
                                    horizontal_alignment: center;
                                    vertical_alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        // === STATUS BAR ===
        Rectangle {
            background: root.window_fill;
            height: 28px;

            HorizontalLayout {
                padding: 8px;

                Text {
                    text: root.status_message;
                    color: root.text_dim;
                    font_size: 12px;
                    vertical_alignment: center;
                }

                Rectangle { horizontal_stretch: 1; }

                Text {
                    text: "IPs: " + root.selected_ip_count;
                    color: root.text_dim;
                    font_size: 12px;
                    vertical_alignment: center;
                }
            }
        }
    }

    // === SETTINGS DIALOG ===
    if (root.settings_dialog_open): Rectangle {
        background: rgba(0, 0, 0, 0.6);

        TouchArea {
            clicked => { root.settings_dialog_open = false; }
        }

        Rectangle {
            background: root.window_fill;
            border_radius: 8px;
            width: 500px;
            height: 520px;
            horizontal_center: parent.horizontal_center;
            vertical_center: parent.vertical_center;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Title
                Text {
                    text: "Settings";
                    color: root.accent;
                    font_size: 18px;
                    font_weight: 700;
                    horizontal_alignment: center;
                }

                // Ping Parameters Section
                Rectangle {
                    background: root.bg;
                    border_radius: 4px;
                    height: 180px;

                    VerticalLayout {
                        padding: 12px;
                        spacing: 10px;

                        Text {
                            text: "Ping Parameters";
                            color: root.accent;
                            font_size: 13px;
                            font_weight: 700;
                        }

                        // Timeout Slider
                        HorizontalLayout {
                            spacing: 8px;

                            Text {
                                text: "Timeout:";
                                color: white;
                                font_size: 12px;
                                width: 100px;
                            }

                            Slider {
                                value <=> root.timeout_value;
                                minimum: 100;
                                maximum: 10000;
                                width: 200px;
                            }

                            Text {
                                text: root.timeout_value + "ms";
                                color: root.text_dim;
                                font_size: 12px;
                                width: 70px;
                            }
                        }

                        // Packet Size Slider
                        HorizontalLayout {
                            spacing: 8px;

                            Text {
                                text: "Packet Size:";
                                color: white;
                                font_size: 12px;
                                width: 100px;
                            }

                            Slider {
                                value <=> root.packet_size_value;
                                minimum: 32;
                                maximum: 65535;
                                width: 200px;
                            }

                            Text {
                                text: root.packet_size_value + " B";
                                color: root.text_dim;
                                font_size: 12px;
                                width: 70px;
                            }
                        }

                        // Interval Slider
                        HorizontalLayout {
                            spacing: 8px;

                            Text {
                                text: "Interval:";
                                color: white;
                                font_size: 12px;
                                width: 100px;
                            }

                            Slider {
                                value <=> root.interval_value;
                                minimum: 100;
                                maximum: 5000;
                                width: 200px;
                            }

                            Text {
                                text: root.interval_value + "ms";
                                color: root.text_dim;
                                font_size: 12px;
                                width: 70px;
                            }
                        }

                        // Max Concurrent Slider
                        HorizontalLayout {
                            spacing: 8px;

                            Text {
                                text: "Max Concurrent:";
                                color: white;
                                font_size: 12px;
                                width: 100px;
                            }

                            Slider {
                                value <=> root.max_concurrent_value;
                                minimum: 1;
                                maximum: 500;
                                width: 200px;
                            }

                            Text {
                                text: root.max_concurrent_value + " threads";
                                color: root.text_dim;
                                font_size: 12px;
                                width: 70px;
                            }
                        }
                    }
                }

                // Options Section
                Rectangle {
                    background: root.bg;
                    border_radius: 4px;
                    height: 100px;

                    VerticalLayout {
                        padding: 12px;
                        spacing: 8px;

                        Text {
                            text: "Options";
                            color: root.accent;
                            font_size: 13px;
                            font_weight: 700;
                        }

                        // CIDR Checkbox
                        HorizontalLayout {
                            spacing: 8px;

                            CheckBox {
                                checked <=> root.cidr_enabled;
                            }

                            Text {
                                text: "Enable CIDR notation support";
                                color: white;
                                font_size: 12px;
                                vertical_alignment: center;
                            }
                        }

                        // Remember Addresses Checkbox
                        HorizontalLayout {
                            spacing: 8px;

                            CheckBox {
                                checked <=> root.remember_addresses;
                            }

                            Text {
                                text: "Remember addresses between sessions";
                                color: white;
                                font_size: 12px;
                                vertical_alignment: center;
                            }
                        }

                        // Debug Mode Checkbox
                        HorizontalLayout {
                            spacing: 8px;

                            CheckBox {
                                checked <=> root.debug_mode;
                            }

                            Text {
                                text: "Debug mode";
                                color: white;
                                font_size: 12px;
                                vertical_alignment: center;
                            }
                        }
                    }
                }

                // Export Fields Section
                Rectangle {
                    background: root.bg;
                    border_radius: 4px;
                    height: 120px;

                    VerticalLayout {
                        padding: 12px;
                        spacing: 6px;

                        Text {
                            text: "Export Fields";
                            color: root.accent;
                            font_size: 13px;
                            font_weight: 700;
                        }

                        // First row of checkboxes
                        HorizontalLayout {
                            spacing: 16px;

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_hostname; }
                                Text { text: "Hostname"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_ip; }
                                Text { text: "IP"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_success; }
                                Text { text: "Success"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_fail; }
                                Text { text: "Fail"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_fail_percent; }
                                Text { text: "Fail%"; color: white; font_size: 11px; vertical_alignment: center; }
                            }
                        }

                        // Second row of checkboxes
                        HorizontalLayout {
                            spacing: 16px;

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_total; }
                                Text { text: "Total"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_rtt; }
                                Text { text: "RTT"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_max; }
                                Text { text: "Max"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_min; }
                                Text { text: "Min"; color: white; font_size: 11px; vertical_alignment: center; }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                CheckBox { checked <=> root.export_avg; }
                                Text { text: "Avg"; color: white; font_size: 11px; vertical_alignment: center; }
                            }
                        }
                    }
                }

                // Buttons
                HorizontalLayout {
                    spacing: 12px;
                    height: 36px;

                    Rectangle {
                        border_radius: 4px;
                        background: root.success;
                        width: 80px;
                        height: 32px;
                        cursor: MouseCursor.pointer;

                        Text {
                            text: "Save";
                            color: white;
                            font_size: 13px;
                            font_weight: 700;
                            horizontal_alignment: center;
                            vertical_alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.save_settings();
                                root.settings_dialog_open = false;
                            }
                        }
                    }

                    Rectangle {
                        border_radius: 4px;
                        background: root.text_dim;
                        width: 80px;
                        height: 32px;
                        cursor: MouseCursor.pointer;

                        Text {
                            text: "Reset";
                            color: white;
                            font_size: 13px;
                            horizontal_alignment: center;
                            vertical_alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.reset_settings();
                            }
                        }
                    }

                    Rectangle { horizontal_stretch: 1; }

                    Rectangle {
                        border_radius: 4px;
                        background: root.fail;
                        width: 80px;
                        height: 32px;
                        cursor: MouseCursor.pointer;

                        Text {
                            text: "Close";
                            color: white;
                            font_size: 13px;
                            font_weight: 700;
                            horizontal_alignment: center;
                            vertical_alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.settings_dialog_open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // === IP WARNING DIALOG ===
    if (root.ip_warning_dialog_open): Rectangle {
        background: rgba(0, 0, 0, 0.6);

        TouchArea {
            clicked => { root.ip_warning_dialog_open = false; }
        }

        Rectangle {
            background: root.window_fill;
            border_radius: 8px;
            width: 400px;
            height: 180px;
            horizontal_center: parent.horizontal_center;
            vertical_center: parent.vertical_center;

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                // Warning Icon/Title
                Text {
                    text: "⚠ Warning";
                    color: root.warning;
                    font_size: 18px;
                    font_weight: 700;
                    horizontal_alignment: center;
                }

                // Warning Message
                Text {
                    text: "You have entered more than 1000 IP addresses. This may cause high memory usage and slow performance. Do you want to continue?";
                    color: white;
                    font_size: 13px;
                    horizontal_alignment: center;
                    wrap: TextWrap.wrap;
                }

                // Buttons
                HorizontalLayout {
                    spacing: 16px;
                    height: 36px;

                    Rectangle {
                        border_radius: 4px;
                        background: root.success;
                        width: 100px;
                        height: 32px;
                        cursor: MouseCursor.pointer;

                        Text {
                            text: "Continue";
                            color: white;
                            font_size: 13px;
                            font_weight: 700;
                            horizontal_alignment: center;
                            vertical_alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.ip_warning_continue();
                                root.ip_warning_dialog_open = false;
                            }
                        }
                    }

                    Rectangle { horizontal_stretch: 1; }

                    Rectangle {
                        border_radius: 4px;
                        background: root.fail;
                        width: 80px;
                        height: 32px;
                        cursor: MouseCursor.pointer;

                        Text {
                            text: "Cancel";
                            color: white;
                            font_size: 13px;
                            font_weight: 700;
                            horizontal_alignment: center;
                            vertical_alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.ip_warning_cancel();
                                root.ip_warning_dialog_open = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // === ABOUT DIALOG ===
    if (root.about_dialog_open): Rectangle {
        background: rgba(0, 0, 0, 0.6);

        TouchArea {
            clicked => { root.about_dialog_open = false; }
        }

        Rectangle {
            background: root.window_fill;
            border_radius: 8px;
            width: 360px;
            height: 280px;
            horizontal_center: parent.horizontal_center;
            vertical_center: parent.vertical_center;

            VerticalLayout {
                padding: 24px;
                spacing: 12px;

                // App Name
                Text {
                    text: "PingTest";
                    color: root.accent;
                    font_size: 24px;
                    font_weight: 700;
                    horizontal_alignment: center;
                }

                // Version
                Text {
                    text: "Version v1.1.0";
                    color: root.text_dim;
                    font_size: 14px;
                    horizontal_alignment: center;
                }

                // Separator
                Rectangle {
                    background: root.text_dim;
                    height: 1px;
                }

                // Description
                Text {
                    text: "A powerful network ping testing tool with support for single IPs, CIDR notation, concurrent pinging, and detailed statistics.";
                    color: white;
                    font_size: 13px;
                    horizontal_alignment: center;
                    wrap: TextWrap.wrap;
                }

                Rectangle { vertical_stretch: 1; }

                // Copyright
                Text {
                    text: "© 2026 PingTest. All rights reserved.";
                    color: root.text_dim;
                    font_size: 12px;
                    horizontal_alignment: center;
                }

                // Close Button
                Rectangle {
                    border_radius: 4px;
                    background: root.accent;
                    width: 100px;
                    height: 36px;
                    cursor: MouseCursor.pointer;
                    horizontal_alignment: center;

                    Text {
                        text: "Close";
                        color: white;
                        font_size: 14px;
                        font_weight: 700;
                        horizontal_alignment: center;
                        vertical_alignment: center;
                    }

                    TouchArea {
                        clicked => {
                            root.close_about();
                            root.about_dialog_open = false;
                        }
                    }
                }
            }
        }
    }
}

// === TABLE ROW STRUCTURE ===
// (moved to top of file)
// (this comment prevents empty trailing lines)
